<div class="form-container">

    <h2 header>Add New Book</h2>

    <% if (errorMessage) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong>
            <%= errorMessage %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
                </button>
        </div>
        <% } %>

            <form action="/add-product" method="POST" enctype="multipart/form-data" novalidate>

                <div class="form-group">
                    <label>Book ID</label>
                    <input type="number" name="id" class="form-control" value="<%= formData.id || '' %>">
                </div>

                <div class="form-group">
                    <label>Book Name</label>
                    <input type="text" name="name" class="form-control" value="<%= formData.name || '' %>">
                </div>

                <div class="form-group">
                    <label>Author</label>
                    <input type="text" name="desc" class="form-control" value="<%= formData.desc || '' %>">
                </div>

                <div class="form-group">
                    <label>Category</label>

                    <select name="price" class="form-control">

                        <option value="">Select Category</option>

                        <option value="Programming" <%=formData.price=="Programming" ? "selected" : "" %>>
                            Programming
                        </option>

                        <option value="Finance" <%=formData.price=="Finance" ? "selected" : "" %>>
                            Finance
                        </option>

                        <option value="Self Improvement" <%=formData.price=="Self Improvement" ? "selected" : "" %>>
                            Self Improvement
                        </option>

                        <option value="Business" <%=formData.price=="Business" ? "selected" : "" %>>
                            Business
                        </option>

                        <option value="Technology" <%=formData.price=="Technology" ? "selected" : "" %>>
                            Technology
                        </option>

                        <option value="Science" <%=formData.price=="Science" ? "selected" : "" %>>
                            Science
                        </option>

                    </select>

                </div>

                <div class="form-group">
                    <label>Stock</label>

                    <input type="number" name="stock" class="form-control" value="<%= formData.stock || '' %>">
                </div>

                <div class="form-group">

                    <label>Status</label>

                    <select name="status" class="form-control">

                        <option value="Available" <%=formData.status=="Available" ? "selected" : "" %>>
                            Available
                        </option>

                        <option value="Low Stock" <%=formData.status=="Low Stock" ? "selected" : "" %>>
                            Low Stock
                        </option>

                        <option value="Out of Stock" <%=formData.status=="Out of Stock" ? "selected" : "" %>>
                            Out of Stock
                        </option>

                    </select>

                </div>

                <div class="form-group">

                    <label>Image URL</label>

                    <!-- <input type="text" name="imageUrl" class="form-control" value="<%= formData.imageUrl || '' %>"> -->
<input type="file" name="imageUrl" class="form-control" accept="image/*">
                </div>

                <br>

                <button class="btn btn-success">
                    Add Product
                </button>

            </form>

</div>