<div class="form-container">

    <h2 header>Update Product</h2>

    <% if (errorMessage) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong>
            <%= errorMessage %>

                <button type="button" class="btn-close" data-bs-dismiss="alert">
                </button>

        </div>
        <% } %>

            <form action="/update-product" method="POST">

                <input type="hidden" name="id" value="<%= product.id %>">

                <div class="form-group">

                    <label>Book Name</label>

                    <input type="text" name="name" class="form-control" value="<%= product.name %>">

                </div>

                <div class="form-group">

                    <label>Author</label>

                    <input type="text" name="desc" class="form-control" value="<%= product.desc %>">

                </div>

                <div class="form-group">

                    <label>Category</label>

                    <select name="price" class="form-control">

                        <option value="Programming" <%=product.price=="Programming" ? "selected" : "" %>>
                            Programming
                        </option>

                        <option value="Finance" <%=product.price=="Finance" ? "selected" : "" %>>
                            Finance
                        </option>

                        <option value="Self Improvement" <%=product.price=="Self Improvement" ? "selected" : "" %>>
                            Self Improvement
                        </option>

                        <option value="Business" <%=product.price=="Business" ? "selected" : "" %>>
                            Business
                        </option>

                        <option value="Technology" <%=product.price=="Technology" ? "selected" : "" %>>
                            Technology
                        </option>

                        <option value="Science" <%=product.price=="Science" ? "selected" : "" %>>
                            Science
                        </option>

                    </select>

                </div>

                <div class="form-group">

                    <label>Stock</label>

                    <input type="number" name="stock" class="form-control" value="<%= product.stock %>">

                </div>

                <div class="form-group">

                    <label>Status</label>

                    <select name="status" class="form-control">

                        <option value="Available" <%=product.status=="Available" ? "selected" : "" %>>
                            Available
                        </option>

                        <option value="Low Stock" <%=product.status=="Low Stock" ? "selected" : "" %>>
                            Low Stock
                        </option>

                        <option value="Out of Stock" <%=product.status=="Out of Stock" ? "selected" : "" %>>
                            Out of Stock
                        </option>

                    </select>

                </div>

                <div class="form-group">

                    <label>Image URL</label>

                    <input type="text" name="imageUrl" class="form-control" value="<%= product.imageUrl %>">

                </div>

                <br>

                <button class="btn btn-primary">
                    Update Product
                </button>

            </form>

</div>